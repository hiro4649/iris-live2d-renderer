{
  "marker": "CODEX_QUALITY_HARNESS_FILE v1.0.7",
  "schemaVersion": "0.8.4",
  "title": "Codex Open PR Hygiene Report",
  "type": "object",
  "required": ["pullRequests", "safeSummaryOnly"],
  "properties": {
    "pullRequests": { "type": "array" },
    "recommendations": {
      "type": "array",
      "items": {
        "enum": ["keep_open", "refresh_required", "close_candidate", "blocked_until_baseline", "owner_decision_required"]
      }
    },
    "safeSummaryOnly": { "const": true }
  },
  "additionalProperties": true
}
