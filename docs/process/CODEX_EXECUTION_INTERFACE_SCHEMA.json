{
  "marker": "CODEX_QUALITY_HARNESS_FILE v1.0.3",
  "harnessVersion": "0.8.8",
  "schemaVersion": "1.0.0",
  "type": "object",
  "required": ["status", "requiredTools", "availableTools", "missingTools", "missingToolImpact", "safeSummaryOnly"],
  "properties": {
    "status": { "enum": ["pass", "warning", "manual_confirmation_required", "fail", "not_applicable"] },
