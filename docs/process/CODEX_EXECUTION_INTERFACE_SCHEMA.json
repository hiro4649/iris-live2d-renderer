    "availableTools": { "type": "array", "items": { "type": "string" } },
    "missingTools": { "type": "array", "items": { "type": "string" } },
    "missingToolImpact": { "enum": ["none", "weakens_evidence", "blocks_verification"] },
    "reasonCodes": { "type": "array", "items": { "type": "string" } },
    "safeSummaryOnly": { "const": true }
  },
  "additionalProperties": true,
  "safeSummaryOnly": true
}
